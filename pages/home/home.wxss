.scrollarea {
  height: 100vh;
  overflow-y: auto;
}

.header-section {
  padding: 20rpx 32rpx 16rpx;
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.date-day {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.date-week {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.checkin-btn {
  background: var(--primary-bg);
  color: var(--primary);
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.encouragement {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
  font-style: italic;
}

.countdown-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.countdown-half {
  flex: 1;
}

.progress-card {
  margin: 0 32rpx 24rpx;
}

.progress-num {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

.progress-detail {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.detail-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.task-section {
  margin-bottom: 24rpx;
}

.task-count {
  font-size: 24rpx;
  font-weight: 500;
}

.task-list {
  padding: 0 32rpx;
}

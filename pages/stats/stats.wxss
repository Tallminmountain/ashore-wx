.scrollarea {
  height: 100vh;
  overflow-y: auto;
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 12rpx;
  padding: 20rpx 32rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 8rpx;
  box-shadow: var(--shadow);
}

.overview-item.highlight {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
}

.ov-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.overview-item.highlight .ov-value {
  color: #fff;
}

.ov-label {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.overview-item.highlight .ov-label {
  color: rgba(255, 255, 255, 0.8);
}

.stats-row {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.ielts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}

.ielts-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--ielts-bg);
  border-radius: 16rpx;
  padding: 20rpx 8rpx;
}

.ielts-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.ielts-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.ielts-count {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ielts);
  margin-top: 4rpx;
}

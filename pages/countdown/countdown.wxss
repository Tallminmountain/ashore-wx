.scrollarea {
  height: 100vh;
  overflow-y: auto;
}

.countdown-section {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  box-shadow: var(--shadow);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.countdown-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
}

.countdown-section.grad::before {
  background: linear-gradient(90deg, var(--grad), var(--primary-light));
}

.countdown-section.ielts::before {
  background: linear-gradient(90deg, var(--ielts), #7B7BF7);
}

.cd-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.cd-emoji {
  font-size: 40rpx;
}

.cd-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.cd-number-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.cd-number {
  font-size: 120rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.countdown-section.grad .cd-number {
  color: var(--grad);
}

.countdown-section.ielts .cd-number {
  color: var(--ielts);
}

.cd-unit {
  font-size: 32rpx;
  color: var(--text-hint);
  font-weight: 500;
}

.cd-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.cd-target {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.cd-date {
  font-size: 24rpx;
  color: var(--text-hint);
}

.cd-reminder {
  background: var(--bg);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.cd-edit {
  font-size: 24rpx;
  color: var(--primary);
  padding: 8rpx;
}

.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

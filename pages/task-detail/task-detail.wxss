.scrollarea {
  height: 100vh;
  overflow-y: auto;
}

.detail-header {
  margin: 16rpx 32rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 20rpx;
  display: block;
}

.detail-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  display: block;
  line-height: 1.6;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 12rpx;
}

.info-cell {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ic-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.ic-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.action-group {
  padding: 0 32rpx;
}

.action-full {
  margin-bottom: 16rpx;
  display: block;
  text-align: center;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.action-half {
  flex: 1;
  text-align: center;
}

.delete-btn {
  text-align: center;
  color: var(--text-hint);
  font-size: 26rpx;
  padding: 24rpx;
}

.form-section {
  padding: 16rpx 32rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.form-textarea {
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}

.type-switch {
  display: flex;
  gap: 16rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.type-btn.active {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
  font-weight: 600;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option-chip {
  padding: 12rpx 24rpx;
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.option-chip.selected {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
}

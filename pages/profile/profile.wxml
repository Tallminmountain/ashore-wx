<navigation-bar title="我的" back="{{false}}" color="black" background="#F5F7FA"></navigation-bar>

<scroll-view class="scrollarea" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="container">

    <!-- 用户信息头部 -->
    <view class="profile-header">
      <view class="avatar" bindtap="changeAvatar">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"></image>
        <text wx:else class="avatar-text">{{userInfo.nickname ? userInfo.nickname[0] : '学'}}</text>
        <view class="avatar-badge">📷</view>
      </view>
      <text class="nickname" bindtap="editNickname">{{userInfo.nickname || '点击设置昵称'}}</text>
      <view class="header-stats">
        <view class="hs-item">
          <text class="hs-num">{{consecutiveDays}}</text>
          <text class="hs-label">连续打卡</text>
        </view>
        <view class="hs-divider"></view>
        <view class="hs-item">
          <text class="hs-num">{{totalStudyMinutes}}</text>
          <text class="hs-label">学习分钟</text>
        </view>
        <view class="hs-divider"></view>
        <view class="hs-item">
          <text class="hs-num">{{completedTasks}}</text>
          <text class="hs-label">完成任务</text>
        </view>
      </view>
    </view>

    <!-- 学习目标 -->
    <view class="menu-group">
      <text class="group-title">🎯 学习目标</text>
      <view class="menu-item" bindtap="goGoalSetup">
        <text class="mi-icon">📝</text>
        <text class="mi-text">设置考研/雅思目标</text>
        <text class="mi-arrow">→</text>
      </view>
    </view>

    <!-- 学习设置 -->
    <view class="menu-group">
      <text class="group-title">⚙️ 学习设置</text>
      <view class="menu-item" bindtap="editDailyHours">
        <text class="mi-icon">⏰</text>
        <text class="mi-text">每日学习时间</text>
        <text class="mi-value">{{userInfo.dailyStudyHours || 4}}小时</text>
        <text class="mi-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="editIeltsHours">
        <text class="mi-icon">🌍</text>
        <text class="mi-text">每日雅思时间</text>
        <text class="mi-value">{{userInfo.dailyIeltsHours || 1}}小时</text>
        <text class="mi-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="editPomodoro">
        <text class="mi-icon">🍅</text>
        <text class="mi-text">番茄钟设置</text>
        <text class="mi-value">{{pomodoroText}}</text>
        <text class="mi-arrow">→</text>
      </view>
    </view>

    <!-- 目标信息 -->
    <view class="menu-group" wx:if="{{userInfo.gradTargetSchool || userInfo.ieltsTargetScore}}">
      <text class="group-title">📋 目标信息</text>
      <view class="info-list" wx:if="{{userInfo.gradTargetSchool}}">
        <view class="info-row">
          <text class="info-label">目标院校</text>
          <text class="info-value">{{userInfo.gradTargetSchool}}</text>
        </view>
        <view class="info-row" wx:if="{{userInfo.gradTargetMajor}}">
          <text class="info-label">目标专业</text>
          <text class="info-value">{{userInfo.gradTargetMajor}}</text>
        </view>
        <view class="info-row" wx:if="{{userInfo.gradExamDate}}">
          <text class="info-label">考研时间</text>
          <text class="info-value">{{userInfo.gradExamDate}}</text>
        </view>
      </view>
      <view class="info-list" wx:if="{{userInfo.ieltsTargetScore}}">
        <view class="info-row">
          <text class="info-label">雅思目标</text>
          <text class="info-value">{{userInfo.ieltsTargetScore}}分</text>
        </view>
        <view class="info-row" wx:if="{{userInfo.ieltsExamDate}}">
          <text class="info-label">考试时间</text>
          <text class="info-value">{{userInfo.ieltsExamDate}}</text>
        </view>
      </view>
    </view>

    <!-- 其他 -->
    <view class="menu-group">
      <text class="group-title">🛠️ 其他</text>
      <view class="menu-item" bindtap="clearData">
        <text class="mi-icon">🗑️</text>
        <text class="mi-text" style="color: var(--danger);">清除所有数据</text>
        <text class="mi-arrow">→</text>
      </view>
    </view>

    <view class="version">上岸计划 v1.0.0</view>

    <view style="height: 260rpx;"></view>
  </view>
</scroll-view>

<tab-bar selected="{{4}}"></tab-bar>

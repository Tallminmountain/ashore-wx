.scrollarea {
  height: 100vh;
  overflow-y: auto;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #EBF2FC 0%, #F5F7FA 100%);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
  overflow: visible;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.avatar-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.header-stats {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  box-shadow: var(--shadow);
  width: 100%;
  box-sizing: border-box;
}

.hs-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hs-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.hs-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.hs-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--border);
}

.menu-group {
  margin: 0 32rpx 24rpx;
}

.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  box-shadow: var(--shadow);
}

.mi-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.mi-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.mi-value {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-right: 8rpx;
}

.mi-arrow {
  color: var(--text-hint);
  font-size: 28rpx;
}

.info-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
  box-shadow: var(--shadow);
  margin-bottom: 8rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-hint);
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.version {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 48rpx;
}

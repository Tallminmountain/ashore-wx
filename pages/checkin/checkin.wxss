.scrollarea {
  height: 100vh;
  overflow-y: auto;
}

.summary-card {
  margin-top: 16rpx;
}

.summary-grid {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
}

.sum-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.sum-icon {
  font-size: 36rpx;
}

.sum-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.sum-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.all-done-banner {
  text-align: center;
  color: var(--success);
  font-size: 28rpx;
  font-weight: 500;
}

.feeling-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.feeling-item {
  padding: 16rpx 24rpx;
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 32rpx;
  font-size: 26rpx;
}

.feeling-item.selected {
  background: var(--primary-bg);
  border-color: var(--primary);
  color: var(--primary);
}

.checkin-action {
  padding: 32rpx;
}

.checkin-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}

.cb-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.cb-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.checkin-success {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.success-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.success-enc {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-style: italic;
  margin-bottom: 48rpx;
}

.success-stats {
  display: flex;
  gap: 48rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: var(--shadow);
}

.ss-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ss-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
}

.ss-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.task-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow);
  transition: opacity 0.3s;
}

.task-card.completed {
  opacity: 0.6;
}

.task-left {
  margin-right: 20rpx;
}

.task-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-icon-wrap.grad {
  background: var(--grad-bg);
}

.task-icon-wrap.ielts {
  background: var(--ielts-bg);
}

.task-icon {
  font-size: 36rpx;
}

.task-body {
  flex: 1;
  min-width: 0;
}

.task-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.task-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.task-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.task-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.task-status {
  font-size: 24rpx;
  font-weight: 500;
}

.task-actions {
  margin-left: 12rpx;
}

.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
}

.action-btn.start {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
}

.action-btn.done {
  background: var(--success-bg);
  color: var(--success);
}

.task-check {
  margin-left: 12rpx;
  font-size: 36rpx;
}

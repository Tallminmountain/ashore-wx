<view class="chart-pie-wrap">
  <!-- 用纯 view 模拟饼图 -->
  <view class="pie-visual" style="width: {{size}}rpx; height: {{size}}rpx;">
    <view class="pie-center">
      <text class="pie-total">{{total}}</text>
      <text class="pie-total-label">总计</text>
    </view>
  </view>
  <!-- 图例 -->
  <view class="pie-legend">
    <view class="legend-item" wx:for="{{segments}}" wx:key="label">
      <view class="legend-dot" style="background: {{item.color}};"></view>
      <text class="legend-label">{{item.label}}</text>
      <text class="legend-value">{{item.value}} ({{item.percent}}%)</text>
    </view>
  </view>
</view>

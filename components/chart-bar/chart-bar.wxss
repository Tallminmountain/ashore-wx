.chart-bar {
  width: 100%;
}

.bar-list {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-around;
  height: 100%;
  padding-bottom: 40rpx;
  position: relative;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.bar-value {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.bar-track {
  width: 40rpx;
  height: 80%;
  background: #F0F0F5;
  border-radius: 8rpx 8rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.bar-fill {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.5s ease;
  min-height: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
  position: absolute;
  bottom: 0;
}

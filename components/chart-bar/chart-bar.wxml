<view class="chart-bar" style="height: {{height}}rpx;">
  <view class="bar-list">
    <view class="bar-item" wx:for="{{chartData}}" wx:key="label">
      <view class="bar-value">{{item.value}}</view>
      <view class="bar-track">
        <view class="bar-fill" style="height: {{item.barHeight}}%; background: {{item.color || 'var(--primary)'}};"></view>
      </view>
      <view class="bar-label" wx:if="{{showLabel}}">{{item.label}}</view>
    </view>
  </view>
</view>

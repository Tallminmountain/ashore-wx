<view class="timer-ring-wrap">
  <svg class="ring-svg" viewBox="0 0 260 260">
    <circle class="ring-bg" cx="130" cy="130" r="120" />
    <circle
      class="ring-progress {{running ? 'running' : ''}}"
      cx="130" cy="130" r="120"
      stroke-dasharray="{{circumference}}"
      stroke-dashoffset="{{strokeDashoffset}}"
    />
  </svg>
  <view class="ring-center">
    <text class="ring-time">{{timeDisplay}}</text>
    <text class="ring-label" wx:if="{{label}}">{{label}}</text>
  </view>
</view>

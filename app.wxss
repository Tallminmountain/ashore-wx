/**
 * 全局样式 - 上岸计划
 * 主色调：浅蓝 + 奶油白，简洁清爽有学习氛围
 */

page {
  --primary: #4A90D9;
  --primary-light: #6BA5E7;
  --primary-bg: #EBF2FC;
  --success: #34C759;
  --success-bg: #E8F8ED;
  --warning: #FF9500;
  --warning-bg: #FFF3E0;
  --danger: #FF3B30;
  --ielts: #5856D6;
  --ielts-bg: #EEEEFF;
  --grad: #007AFF;
  --grad-bg: #E8F4FD;
  --bg: #F5F7FA;
  --card-bg: #FFFFFF;
  --text-primary: #1D1D1F;
  --text-secondary: #6E6E73;
  --text-hint: #AEAEB2;
  --border: #E5E5EA;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--bg);
  height: 100vh;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: var(--shadow);
}

/* 标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--primary-bg);
  color: var(--primary);
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

.btn-secondary::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-grad {
  background: var(--grad-bg);
  color: var(--grad);
}

.tag-ielts {
  background: var(--ielts-bg);
  color: var(--ielts);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
  text-align: center;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* Flex 工具 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}
